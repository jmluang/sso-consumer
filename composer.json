{
    "name": "jmluang/sso-consumer",
    "description": "Laravel SSO consumer package that verifies portal-signed JWT tickets and bridges upstream identity to local admin auth.",
    "keywords": [
        "jmluang",
        "laravel",
        "sso",
        "sso-consumer",
        "jwt"
    ],
    "homepage": "https://github.com/jmluang/sso-consumer",
    "license": "MIT",
    "authors": [
        {
            "name": "jmluang",
            "email": "jmluang@example.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^11.0 || ^12.0 || ^13.0",
        "illuminate/contracts": "^11.0 || ^12.0 || ^13.0",
        "firebase/php-jwt": "^6.10"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "larastan/larastan": "^3.0",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Jmluang\\SsoConsumer\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Jmluang\\SsoConsumer\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html=build/coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Jmluang\\SsoConsumer\\SsoConsumerServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
